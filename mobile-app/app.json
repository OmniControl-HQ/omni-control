{
  "expo": {
    "name": "OmniControl",
    "slug": "omnicontrol-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "omnicontrol",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.omnicontrol.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0b0f19"
      },
      "package": "com.omnicontrol.mobile"
    },
    "web": {
      "backgroundColor": "#0b0f19",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
